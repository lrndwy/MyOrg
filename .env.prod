# myorg — Environment Variables
#
# ═══════════════════════════════════════════════════════════════════════════
# DEPLOY / HOST — ganti sebelum up ke server
# ═══════════════════════════════════════════════════════════════════════════
# Variabel bertanda [HOST] di bawah WAJIB diganti dari localhost ke host
# publik server. Pilih salah satu pola:
#
# ── A) Akses via IP (tanpa domain, HTTP) ───────────────────────────────────
#    Contoh IP server: 203.0.113.10
#      APP_URL=http://203.0.113.10:8080
#      API_URL=http://203.0.113.10:8080
#      NEXT_PUBLIC_WEB_URL=http://203.0.113.10:3000
#      NEXT_PUBLIC_ADMIN_URL=http://203.0.113.10:3001
#      OAUTH_FRONTEND_URL=http://203.0.113.10:3000
#      CORS_ORIGINS=http://203.0.113.10:3000,http://203.0.113.10:3001
#      MINIO_ENDPOINT=http://203.0.113.10:9002   # jika browser/client akses MinIO langsung
#
# ── B) Akses via domain (+ HTTPS, reverse proxy) ───────────────────────────
#    Contoh: api.myorg.id · app.myorg.id · admin.myorg.id
#      APP_URL=https://api.myorg.id
#      API_URL=https://api.myorg.id
#      NEXT_PUBLIC_WEB_URL=https://app.myorg.id
#      NEXT_PUBLIC_ADMIN_URL=https://admin.myorg.id
#      OAUTH_FRONTEND_URL=https://app.myorg.id
#      CORS_ORIGINS=https://app.myorg.id,https://admin.myorg.id
#      MINIO_ENDPOINT=https://files.myorg.id      # atau CDN/S3 publik
#
# Catatan penting:
#   • API_URL & NEXT_PUBLIC_* di-bake saat `pnpm build` — rebuild frontend
#     setelah mengubah nilai ini.
#   • CORS_ORIGINS harus tepat sama dengan origin browser (scheme+host+port).
#   • OAuth: daftarkan callback URL di Google/GitHub sesuai OAUTH_FRONTEND_URL.
#   • POSTGRES_HOST / REDIS_URL: tetap nama service Docker (bukan IP publik)
#     jika API jalan di container yang sama network-nya.
#   • APP_ENV=production di server; rotasi JWT_SECRET, password Pulse/Sentinel.
# ═══════════════════════════════════════════════════════════════════════════


# Port
API_PORT=8080
WEB_PORT=3000
ADMIN_PORT=3001
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
OCR_PORT=8884
REDIS_PORT=6380

# App
APP_NAME=myorg
APP_ENV=production
APP_PORT=8080

# [HOST] URL publik API (dipakai redirect, cookie context, link internal backend).
APP_URL=https://api-himatris.heroflow.my.id
# [HOST] Tujuan redirect setelah OAuth (login terpusat di Web).
OAUTH_FRONTEND_URL=https://himatris.heroflow.my.id
# Redis
REDIS_URL=redis://localhost:6380
# [HOST] Public API URL — baked into Next.js bundles at build time.
API_URL=https://api-himatris.heroflow.my.id
# [HOST] Admin panel URL (navbar Web → link Admin, redirect antar-app).
NEXT_PUBLIC_ADMIN_URL=https://admin-himatris.heroflow.my.id
# [HOST] Web / portal anggota (login terpusat, redirect dari admin).
NEXT_PUBLIC_WEB_URL=https://himatris.heroflow.my.id
# Share auth + CSRF cookies across web / admin / API subdomains.
AUTH_COOKIE_DOMAIN=.heroflow.my.id
# MinIO S3 API (bukan console). Port 9000 = API upload/download; 9001 = web console saja.
MINIO_ENDPOINT=http://localhost:9000
# URL publik untuk link file di browser. Sama dengan MINIO_ENDPOINT jika API jalan di host.
MINIO_PUBLIC_URL=http://localhost:9000


# ─── Database (Postgres) ────────────────────────────────────────────────
POSTGRES_USER=grit
POSTGRES_PASSWORD=c30f445ea6fa1a1bf2dcb24efcffa6a2f7d7e0c8bf8e72e5
POSTGRES_DB=myorg
POSTGRES_HOST=localhost
POSTGRES_PORT=5434

# Storage — Which provider to use: minio, s3, r2, b2
STORAGE_DRIVER=minio

# Minio
MINIO_ACCESS_KEY=M1n104dmin
MINIO_SECRET_KEY=M1n104dmin
MINIO_BUCKET=myorg-uploads
MINIO_REGION=us-east-1
MINIO_USE_SSL=false

# JWT — generated at scaffold time. Rotate with: openssl rand -hex 32
JWT_SECRET=e1cc5e7ec16b2cd2043086b46cd0f51dadb39ee813932d21da05384efb0265d4
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# OAuth2 — Social Login (Google + GitHub)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AWS S3 (used when STORAGE_DRIVER=s3)
# Leave S3_ENDPOINT empty to use the AWS regional default.
# S3_ACCESS_KEY + S3_SECRET_KEY fall back to AWS_ACCESS_KEY_ID +
# AWS_SECRET_ACCESS_KEY (and S3_REGION to AWS_REGION) so an IAM role
# attached to your EC2 / ECS / Lambda Just Works.
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=us-east-1

# Cloudflare R2 (used when STORAGE_DRIVER=r2)
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_REGION=auto

# Backblaze B2 (used when STORAGE_DRIVER=b2)
B2_ENDPOINT=
B2_ACCESS_KEY=
B2_SECRET_KEY=
B2_BUCKET=
B2_REGION=us-west-004

# OCR — Tesseract over HTTP (local dev via docker compose service `ocr`).
# Leave empty when the API runs inside Docker (apps/api/Dockerfile installs tesseract).
# Dev (API on host): http://localhost:8884
# TESSERACT_HTTP_URL=http://localhost:8884
#
# PDF hasil scan fisik: API perlu `pdftoppm` (poppler) untuk konversi halaman ke gambar
# sebelum OCR jika Tesseract tidak bisa membaca PDF langsung.
# Dev (API on host): brew install poppler
# Docker API image sudah include poppler-utils.

# Email (Resend)
RESEND_API_KEY=re_your_api_key
MAIL_FROM=noreply@myorg.dev

# Support inbox — every ticket opened in /system/support is emailed here
# (when RESEND_API_KEY is set). Leave empty in dev to skip email-out.
SUPPORT_EMAIL=

# CORS
# [HOST] Origin browser yang boleh memanggil API (Web + Admin). Harus exact
# match: scheme + host + port. Tanpa trailing slash.
# Dev: http://localhost:3000,http://localhost:3001
# IP:  http://203.0.113.10:3000,http://203.0.113.10:3001
# Domain: https://app.myorg.id,https://admin.myorg.id
# The Wails desktop webview does NOT need an entry here: its origin varies
# (http://wails.localhost:34115 in dev, http://wails.localhost in a Windows
# build, wails://wails on macOS/Linux), so the CORS middleware matches the
# wails.localhost host on any port instead.
CORS_ORIGINS=https://himatris.heroflow.my.id,https://admin-himatris.heroflow.my.id

# GORM Studio
GORM_STUDIO_ENABLED=true
GORM_STUDIO_USERNAME=admin
GORM_STUDIO_PASSWORD=studio

# AI — Vercel AI Gateway (one key, hundreds of models)
AI_GATEWAY_API_KEY=                           # Get from vercel.com/ai-gateway
AI_GATEWAY_MODEL=anthropic/claude-sonnet-4-6  # provider/model format
AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1

# Two-Factor Authentication (TOTP)
TOTP_ISSUER=myorg

# Web Push (PWA announcement notifications)
# Generate: cd apps/api && go run ./cmd/vapidgen
# Required for push when a new announcement is published.
# Browser needs HTTPS (or localhost). iOS: add to Home Screen first.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@localhost
# Optional mirror for client-side subscribe (web fetches key from API by default)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Observability — Pulse performance monitoring dashboard
# Pulse refuses to mount in APP_ENV=production with the literal default
# password "pulse" — the value below is generated at scaffold time so the
# gate is satisfied. Rotate with: openssl rand -hex 16
PULSE_ENABLED=true
PULSE_USERNAME=admin
PULSE_PASSWORD=75de3db4ff32599a4181b3b0b07eb524

# Security — Sentinel WAF, rate limiting, threat detection
# Same as Pulse: Sentinel refuses to mount in production with default
# credentials. SECRET_KEY needs at least 32 bytes of entropy — both values
# below are generated per scaffold. Rotate with: openssl rand -hex 16 (password)
# / openssl rand -hex 32 (secret key).
SENTINEL_ENABLED=true
SENTINEL_USERNAME=admin
SENTINEL_PASSWORD=607d14ff8ac81cc597e73e72ad310234
SENTINEL_SECRET_KEY=0ea0cd305319eeecfd3613699a2bd0d186e62db0c59862c5ce326cab6fed777f

# ─── Theme (v3.28+) ────────────────────────────────────────────────────
# Picks the visual identity for auth pages and the dashboard. Options:
#   atlas  — split-screen, team/organisation, Inter (default)
#   aurora — centered Clerk-style, consumer SaaS, Geist
#   pulse  — split-screen with carousel, ecommerce/brand, Onest + DM Serif
# Mirrored into NEXT_PUBLIC_THEME for the web + admin clients in
# next.config — the apps read it at build time so server components render
# the right theme without a flash of unstyled content.
THEME=atlas

# Social login buttons (Google + GitHub). Set to false to hide them from
# auth pages and remove the "or continue with" divider. The OAuth API
# routes stay registered server-side either way; flipping this only
# changes what the UI renders. NEXT_PUBLIC_SOCIAL_AUTH_ENABLED mirrors
# the value to the browser bundle.
SOCIAL_AUTH_ENABLED=true
TESSERACT_HTTP_URL=http://localhost:8884
